# Public Supabase project config (safe for browser usage)
# In production, use an https URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical app origin used for auth email redirects.
# Set this in Vercel Production to your deployed domain, without a trailing slash.
# For Preview, either omit it or set a preview-specific URL instead of reusing production.
NEXT_PUBLIC_APP_URL=

# Server-only key for future admin tasks (not required for the current MVP deploy)
SUPABASE_SERVICE_ROLE_KEY=
